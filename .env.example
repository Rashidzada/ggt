DJANGO_SECRET_KEY=replace-with-a-long-random-secret-key
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
DJANGO_TIME_ZONE=Asia/Karachi
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gogreentech
WHATSAPP_NUMBER=03470983567
SITE_URL=http://127.0.0.1:8000
VITE_API_URL=http://127.0.0.1:8000/api
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_SESSION_COOKIE_SECURE=0
DJANGO_CSRF_COOKIE_SECURE=0
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=0
DJANGO_SECURE_HSTS_PRELOAD=0
DJANGO_TRUST_X_FORWARDED_PROTO=1
# Flutter reads this at build/run time:
# flutter run --dart-define=API_URL=http://10.0.2.2:8000/api

# Production example for PythonAnywhere + Vercel:
# DJANGO_DEBUG=0
# DJANGO_ALLOWED_HOSTS=yourusername.pythonanywhere.com
# DJANGO_CORS_ALLOWED_ORIGINS=https://your-project.vercel.app
# DJANGO_CSRF_TRUSTED_ORIGINS=https://yourusername.pythonanywhere.com,https://your-project.vercel.app
